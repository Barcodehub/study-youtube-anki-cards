# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Paths (relative to backend/ unless absolute)
# ---------------------------------------------------------------------------
WORKDIR=./temp
OUTPUT_DIR=./output

# ---------------------------------------------------------------------------
# Whisper (used only when the video has no subtitles)
# ---------------------------------------------------------------------------
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto

# ---------------------------------------------------------------------------
# LLM provider: one of "deepseek" | "claude" | "openai"
# ---------------------------------------------------------------------------
LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Segmentation heuristics
# ---------------------------------------------------------------------------
SEGMENT_MIN_SECONDS=20
SEGMENT_MAX_SECONDS=90

# ---------------------------------------------------------------------------
# Subtitle / transcription language (ISO 639-1). "en" = English.
# ---------------------------------------------------------------------------
DEFAULT_LANGUAGE=en

# Delete temp/ contents after each job finishes (true/false)
CLEANUP_AFTER_JOB=true
